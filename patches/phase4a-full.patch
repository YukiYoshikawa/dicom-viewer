+/// Compute importance score for a single slice (0.0 - 1.0).
+/// Based on entropy + edge density. Uses raw pixel data.
+pub fn compute_slice_importance(data: &[u8], width: usize, height: usize) -> f32 {
+    if width == 0 || height == 0 || data.len() < width * height {
+        return 0.0;
+    }
+
+    let total = width * height;
+
+    // Entropy from histogram
+    let mut hist = [0u32; 256];
+    for i in 0..total {
+        hist[data[i] as usize] += 1;
+    }
+    let mut entropy: f32 = 0.0;
+    let total_f = total as f32;
+    for &count in &hist {
+        if count > 0 {
+            let p = count as f32 / total_f;
+            entropy -= p * p.log2();
+        }
+    }
+
+    // Edge density (sampled gradient)
+    let step = if total > 100_000 { 4 } else { 2 };
+    let mut edge_sum: f32 = 0.0;
+    let mut edge_count: u32 = 0;
+    for y in (1..height - 1).step_by(step) {
+        for x in (1..width - 1).step_by(step) {
+            let gx = data[y * width + x + 1] as i32 - data[y * width + x - 1] as i32;
+            let gy = data[(y + 1) * width + x] as i32 - data[(y - 1) * width + x] as i32;
+            edge_sum += ((gx * gx + gy * gy) as f32).sqrt();
+            edge_count += 1;
+        }
+    }
+    let edge_density = if edge_count > 0 { edge_sum / edge_count as f32 } else { 0.0 };
+
+    // Combine: entropy (0-8 range) + edge density (0-~360 range)
+    let entropy_norm = (entropy / 8.0).min(1.0);
+    let edge_norm = (edge_density / 100.0).min(1.0);
+
+    entropy_norm * 0.5 + edge_norm * 0.5
+}
+
+/// Downsample 8-bit grayscale to target size using area averaging.
+/// Used to compute importance scores without loading full-res images.
+pub fn downsample_u8(data: &[u8], src_w: usize, src_h: usize, dst_w: usize, dst_h: usize) -> Vec<u8> {
+    let mut out = vec![0u8; dst_w * dst_h];
+    let sx = src_w as f32 / dst_w as f32;
+    let sy = src_h as f32 / dst_h as f32;
+
+    for dy in 0..dst_h {
+        for dx in 0..dst_w {
+            let x0 = (dx as f32 * sx) as usize;
+            let y0 = (dy as f32 * sy) as usize;
+            let x1 = ((dx + 1) as f32 * sx) as usize;
+            let y1 = ((dy + 1) as f32 * sy) as usize;
+            let x1 = x1.min(src_w);
+            let y1 = y1.min(src_h);
+            let mut sum: u32 = 0;
+            let mut count: u32 = 0;
+            for y in y0..y1 {
+                for x in x0..x1 {
+                    sum += data[y * src_w + x] as u32;
+                    count += 1;
+                }
+            }
+            out[dy * dst_w + dx] = if count > 0 { (sum / count) as u8 } else { 0 };
+        }
+    }
+    out
+}
+
+/// Compute change score between two slices (0.0 - 1.0).
+/// Simple and reliable: mean absolute difference normalized.
+pub fn compute_slice_change_score(current: &[u8], previous: &[u8], width: usize, height: usize) -> f32 {
+    let pixels = width * height;
+    if pixels == 0 || current.len() < pixels || previous.len() < pixels {
+        return 0.0;
+    }
+
+    // Sample for speed
+    let step = if pixels > 100_000 { 4 } else { 1 };
+    let mut diff_sum: u64 = 0;
+    let mut count: u32 = 0;
+    for i in (0..pixels).step_by(step) {
+        diff_sum += (current[i] as i32 - previous[i] as i32).unsigned_abs() as u64;
+        count += 1;
+    }
+
+    let mean_diff = diff_sum as f32 / count.max(1) as f32;
+    // Normalize: typical range 0-30, cap at 50
+    (mean_diff / 50.0).min(1.0)
+}
