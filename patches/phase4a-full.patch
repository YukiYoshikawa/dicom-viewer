+/// Slice Change Map: Highlights regions that differ from the previous slice.
+/// Clinically meaningful — shows where anatomy changes between adjacent slices,
+/// useful for detecting lesion boundaries and new findings.
+
+const BLOCK_SIZE: usize = 16;
+
+/// Compute a change map between two 8-bit grayscale images of the same size.
+/// Returns a downscaled heatmap (width/BLOCK_SIZE × height/BLOCK_SIZE) as u8 scores.
+/// Higher values = more change between the two slices.
+pub fn compute_change_map(
+    current: &[u8],
+    previous: &[u8],
+    width: usize,
+    height: usize,
+) -> Vec<u8> {
+    let pixels = width * height;
+    if pixels == 0 || current.len() < pixels || previous.len() < pixels {
+        return vec![];
+    }
+
+    let bw = (width + BLOCK_SIZE - 1) / BLOCK_SIZE;
+    let bh = (height + BLOCK_SIZE - 1) / BLOCK_SIZE;
+    let num_blocks = bw * bh;
+
+    // Per-block: mean absolute difference
+    let mut block_diffs = vec![0.0f32; num_blocks];
+
+    for by in 0..bh {
+        for bx in 0..bw {
+            let idx = by * bw + bx;
+            let x0 = bx * BLOCK_SIZE;
+            let y0 = by * BLOCK_SIZE;
+            let x1 = (x0 + BLOCK_SIZE).min(width);
+            let y1 = (y0 + BLOCK_SIZE).min(height);
+            let block_pixels = (y1 - y0) * (x1 - x0);
+            if block_pixels == 0 { continue; }
+
+            let mut diff_sum: u32 = 0;
+            for y in y0..y1 {
+                for x in x0..x1 {
+                    let pi = y * width + x;
+                    let d = (current[pi] as i32 - previous[pi] as i32).unsigned_abs();
+                    diff_sum += d;
+                }
+            }
+            block_diffs[idx] = diff_sum as f32 / block_pixels as f32;
+        }
+    }
+
+    // Normalize to 0-255 using percentile (ignore top 1% as outlier)
+    let mut sorted_diffs: Vec<f32> = block_diffs.iter()
+        .filter(|d| **d > 0.5) // ignore near-zero blocks
+        .copied()
+        .collect();
+
+    if sorted_diffs.is_empty() {
+        return vec![0u8; num_blocks];
+    }
+
+    sorted_diffs.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
+    let p99_idx = ((sorted_diffs.len() as f32 * 0.99) as usize).min(sorted_diffs.len() - 1);
+    let max_diff = sorted_diffs[p99_idx].max(1.0);
+
+    let mut heatmap = vec![0u8; num_blocks];
+    for i in 0..num_blocks {
+        if block_diffs[i] < 1.0 { continue; } // Skip negligible change
+        let normalized = (block_diffs[i] / max_diff).min(1.0);
+        heatmap[i] = (normalized * 255.0) as u8;
+    }
+
+    heatmap
+}
