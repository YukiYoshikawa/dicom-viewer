+  </div>
+  <div class="card metric">
+    <div class="metric-value">~1ms</div>
+    <div class="metric-label">スライス重要度計算<br>(Smart Reading, Wasm)</div>
+  </div>
+  <div class="card metric">
+    <div class="metric-value">0</div>
+    <div class="metric-label">外部サーバー依存<br>(完全ローカル)</div>
+  </div>
+</div>
