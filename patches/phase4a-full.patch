+    <tbody>
+      <tr><td>CPU-bound ピクセル操作</td><td>フィルタ、ヒストグラム、統計解析</td><td>—</td></tr>
+      <tr><td>GPU レンダリング</td><td>—</td><td>WebGL/WebGPU による画像描画、ボリュームレンダリング</td></tr>
+      <tr><td>DICOM パース</td><td>—</td><td>dicom-parser（既に十分高速）</td></tr>
+      <tr><td>UI イベント処理</td><td>—</td><td>React + Cornerstone Tools</td></tr>
