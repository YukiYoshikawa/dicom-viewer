index 0000000..1ff9879
--- /dev/null
+++ b/src/components/HistogramPanel.tsx
@@ -0,0 +1,99 @@
+import { useRef, useEffect, memo } from 'react';
+import { computeHistogram, isWasmReady } from '../core/wasmBridge';
+import { getRenderingEngine } from '@cornerstonejs/core';
+import { VIEWPORT_ID, RENDERING_ENGINE_ID } from './Viewport';
+import styles from './HistogramPanel.module.css';
+
+interface HistogramPanelProps {
+  windowCenter: number;
+  windowWidth: number;
+}
+
+export const HistogramPanel = memo(function HistogramPanel({ windowCenter, windowWidth }: HistogramPanelProps) {
+  const canvasRef = useRef<HTMLCanvasElement>(null);
+
+  useEffect(() => {
+    const canvas = canvasRef.current;
+    if (!canvas || !isWasmReady()) return;
+
+    const engine = getRenderingEngine(RENDERING_ENGINE_ID);
+    if (!engine) return;
+    const viewport = engine.getStackViewport(VIEWPORT_ID);
+    if (!viewport) return;
+    const srcCanvas = viewport.getCanvas();
+    if (!srcCanvas) return;
+
+    const srcCtx = srcCanvas.getContext('2d', { willReadFrequently: true });
+    if (!srcCtx) return;
+
+    const imageData = srcCtx.getImageData(0, 0, srcCanvas.width, srcCanvas.height);
+    const rgba = imageData.data;
+    const pixels = srcCanvas.width * srcCanvas.height;
+    const grayscale = new Uint8Array(pixels);
+    for (let i = 0; i < pixels; i++) {
+      grayscale[i] = rgba[i * 4];
+    }
+
+    let hist: Uint32Array;
+    try {
+      hist = computeHistogram(grayscale);
+    } catch {
+      return;
+    }
+
+    // Draw histogram
+    const ctx = canvas.getContext('2d');
+    if (!ctx) return;
+
+    const w = canvas.width;
+    const h = canvas.height;
+    ctx.clearRect(0, 0, w, h);
+
+    // Find max (skip 0 and 255 as they're often outliers)
+    let maxVal = 0;
+    for (let i = 1; i < 255; i++) {
+      if (hist[i] > maxVal) maxVal = hist[i];
+    }
+    if (maxVal === 0) return;
+
+    // Draw bars
+    const barWidth = w / 256;
+    ctx.fillStyle = 'rgba(74, 158, 255, 0.6)';
+    for (let i = 0; i < 256; i++) {
+      const barH = (hist[i] / maxVal) * h;
+      ctx.fillRect(i * barWidth, h - barH, barWidth + 0.5, barH);
+    }
+
+    // Draw WL/WW range indicator
+    // Map WC/WW to 0-255 range (approximate)
+    const lower = Math.max(0, ((windowCenter - windowWidth / 2) + 1024) / 4096 * 255);
+    const upper = Math.min(255, ((windowCenter + windowWidth / 2) + 1024) / 4096 * 255);
+
+    ctx.fillStyle = 'rgba(255, 200, 50, 0.15)';
+    ctx.fillRect(lower * barWidth, 0, (upper - lower) * barWidth, h);
+
+    ctx.strokeStyle = 'rgba(255, 200, 50, 0.7)';
+    ctx.lineWidth = 1;
+    ctx.setLineDash([3, 3]);
+    const centerX = ((windowCenter + 1024) / 4096 * 255) * barWidth;
+    ctx.beginPath();
+    ctx.moveTo(centerX, 0);
+    ctx.lineTo(centerX, h);
+    ctx.stroke();
+    ctx.setLineDash([]);
+  }, [windowCenter, windowWidth]);
+
+  if (!isWasmReady()) return null;
+
+  return (
+    <div className={styles.panel}>
+      <div className={styles.title}>ヒストグラム</div>
+      <canvas ref={canvasRef} className={styles.canvas} width={256} height={80} />
+      <div className={styles.stats}>
+        <span>0</span>
+        <span>WC:{Math.round(windowCenter)} WW:{Math.round(windowWidth)}</span>
+        <span>255</span>
+      </div>
+    </div>
+  );
+});
