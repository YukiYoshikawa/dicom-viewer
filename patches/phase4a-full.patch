@@ -0,0 +1,208 @@
+import { useEffect, useRef, useCallback } from 'react';
+import { RenderingEngine, Enums } from '@cornerstonejs/core';
+import type { Types } from '@cornerstonejs/core';
+import { utilities } from '@cornerstonejs/tools';
+import { createToolGroup } from '../core/toolSetup';
+import { applyFilterU8, isWasmReady } from '../core/wasmBridge';
+import type { LayoutType, FilterState, SeriesInfo } from '../types/dicom';
+import styles from './ViewportLayout.module.css';
+
+const LAYOUT_ENGINE_ID = 'layoutRenderingEngine';
+
+interface CellState {
+  viewportId: string;
+  imageIds: string[];
+  seriesIndex: number;
+  currentSlice: number;
+}
+
+interface ViewportLayoutProps {
+  layout: LayoutType;
+  seriesList: SeriesInfo[];
+  activeFilters?: FilterState[];
+  onVoiChange?: (wc: number, ww: number) => void;
+  onImageRendered?: (imageId: string) => void;
+  onSliceChange?: (currentIndex: number, totalSlices: number) => void;
+}
+
+function getCellCount(layout: LayoutType): number {
+  switch (layout) {
+    case '1x1': return 1;
+    case '1x2': return 2;
+    case '2x2': return 4;
+  }
+}
+
+function getGridClass(layout: LayoutType): string {
+  switch (layout) {
+    case '1x1': return styles.grid1x1;
+    case '1x2': return styles.grid1x2;
+    case '2x2': return styles.grid2x2;
+  }
+}
+
+export function ViewportLayout({
+  layout,
+  seriesList,
+  activeFilters,
+  onVoiChange,
+  onImageRendered,
+  onSliceChange,
+}: ViewportLayoutProps) {
+  const cellCount = getCellCount(layout);
+  const cellRefs = useRef<(HTMLDivElement | null)[]>([]);
+  const engineRef = useRef<RenderingEngine | null>(null);
+  const activeIndexRef = useRef(0);
+  const cellStatesRef = useRef<CellState[]>([]);
+
+  const onVoiChangeRef = useRef(onVoiChange);
+  onVoiChangeRef.current = onVoiChange;
+  const onImageRenderedRef = useRef(onImageRendered);
+  onImageRenderedRef.current = onImageRendered;
+  const onSliceChangeRef = useRef(onSliceChange);
+  onSliceChangeRef.current = onSliceChange;
+
+  // Initialize cells — assign series round-robin
+  useEffect(() => {
+    const states: CellState[] = [];
+    for (let i = 0; i < cellCount; i++) {
+      const seriesIdx = i < seriesList.length ? i : 0;
+      const series = seriesList[seriesIdx];
+      states.push({
+        viewportId: `layoutVp_${i}`,
+        imageIds: series?.imageIds ?? [],
+        seriesIndex: seriesIdx,
+        currentSlice: 0,
+      });
+    }
+    cellStatesRef.current = states;
+  }, [cellCount, seriesList]);
+
+  // Create rendering engine and viewports
+  useEffect(() => {
+    const elements = cellRefs.current.slice(0, cellCount);
+    if (elements.some((el) => !el)) return;
+
+    const initTimer = window.setTimeout(() => {
+      const engine = new RenderingEngine(LAYOUT_ENGINE_ID);
+      engineRef.current = engine;
+
+      const inputs: Types.PublicViewportInput[] = cellStatesRef.current.map((cell, i) => ({
+        viewportId: cell.viewportId,
+        type: Enums.ViewportType.STACK,
+        element: elements[i]!,
+      }));
+      engine.setViewports(inputs);
+
+      // Create tool group for all viewports
+      for (const cell of cellStatesRef.current) {
+        createToolGroup(cell.viewportId, LAYOUT_ENGINE_ID);
+      }
+
+      // Load images into each viewport
+      for (const cell of cellStatesRef.current) {
+        if (cell.imageIds.length === 0) continue;
+        const vp = engine.getStackViewport(cell.viewportId);
+        if (!vp) continue;
+        vp.setStack(cell.imageIds, 0).then(() => {
+          vp.render();
+          const el = vp.element;
+          if (el) {
+            utilities.stackPrefetch.setConfiguration({
+              maxImagesToPrefetch: Math.min(cell.imageIds.length, 10),
+              preserveExistingPool: false,
+            });
+            utilities.stackPrefetch.enable(el);
+          }
+        }).catch(console.error);
+      }
+
+      // Event handler for active viewport
+      for (let i = 0; i < elements.length; i++) {
+        const el = elements[i]!;
+        const handler = () => {
+          const eng = engineRef.current;
+          if (!eng) return;
+          const vpId = cellStatesRef.current[i]?.viewportId;
+          if (!vpId) return;
+          const vp = eng.getStackViewport(vpId);
+          if (!vp) return;
+
+          const currentImageId = vp.getCurrentImageId();
+          if (currentImageId && onImageRenderedRef.current && i === activeIndexRef.current) {
+            onImageRenderedRef.current(currentImageId);
+          }
+
+          if (i === activeIndexRef.current) {
+            try {
+              const voiRange = vp.getProperties().voiRange;
+              if (voiRange && onVoiChangeRef.current) {
+                const ww = voiRange.upper - voiRange.lower;
+                const wc = voiRange.lower + ww / 2;
+                onVoiChangeRef.current(wc, ww);
+              }
+            } catch { /* ok */ }
+
+            const idx = vp.getCurrentImageIdIndex();
+            const total = vp.getImageIds().length;
+            if (onSliceChangeRef.current) onSliceChangeRef.current(idx, total);
+          }
+        };
+        el.addEventListener(Enums.Events.IMAGE_RENDERED, handler);
+        (el as unknown as Record<string, unknown>).__layoutHandler = handler;
+      }
+    }, 100);
+
+    return () => {
+      clearTimeout(initTimer);
+      for (const el of elements) {
+        if (!el) continue;
+        // eslint-disable-next-line @typescript-eslint/no-explicit-any
+        const handler = (el as any).__layoutHandler;
+        if (handler) {
+          el.removeEventListener(Enums.Events.IMAGE_RENDERED, handler);
+        }
+        try { utilities.stackPrefetch.disable(el); } catch { /* ok */ }
+      }
+      const engine = engineRef.current;
+      if (engine) {
+        engineRef.current = null;
+        engine.destroy();
+      }
+    };
+  }, [layout, seriesList]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  const handleCellClick = useCallback((index: number) => {
+    activeIndexRef.current = index;
+  }, []);
+
+  return (
+    <div className={`${styles.grid} ${getGridClass(layout)}`}>
+      {Array.from({ length: cellCount }, (_, i) => {
+        const series = seriesList[i < seriesList.length ? i : 0];
+        const label = series
+          ? `${series.modality} - ${series.seriesDescription || `Series ${series.seriesNumber}`}`
+          : '';
+
+        return (
+          <div
+            key={i}
+            className={`${styles.cell} ${activeIndexRef.current === i ? styles.cellActive : ''}`}
+            onClick={() => handleCellClick(i)}
+          >
+            {label && <span className={styles.cellLabel}>{label}</span>}
+            {series ? (
+              <div
+                ref={(el) => { cellRefs.current[i] = el; }}
+                style={{ width: '100%', height: '100%', outline: 'none' }}
+                tabIndex={-1}
+              />
+            ) : (
+              <div className={styles.emptyCell}>シリーズなし</div>
+            )}
+          </div>
+        );
+      })}
+    </div>
+  );
+}
