@@ -0,0 +1,105 @@
+/**
+ * Voice command system using Web Speech API.
+ * Enables hands-free operation for clinical environments.
+ */
+
+export interface VoiceCommandHandler {
+  onCommand: (command: string) => void;
+}
+
+// Japanese + English command mapping
+const COMMAND_MAP: Record<string, string> = {
+  // Navigation
+  '次': 'next', 'つぎ': 'next', 'next': 'next',
+  '前': 'prev', 'まえ': 'prev', 'previous': 'prev', 'back': 'prev',
+  // Tools
+  'ズーム': 'zoom', 'zoom': 'zoom', 'ずーむ': 'zoom',
+  'パン': 'pan', 'pan': 'pan', 'ぱん': 'pan',
+  '回転': 'rotate', 'かいてん': 'rotate', 'rotate': 'rotate',
+  'ウィンドウ': 'windowLevel', 'window': 'windowLevel',
+  '計測': 'length', 'けいそく': 'length', 'measure': 'length',
+  '角度': 'angle', 'かくど': 'angle', 'angle': 'angle',
+  // Actions
+  'リセット': 'reset', 'りせっと': 'reset', 'reset': 'reset',
+  'フィット': 'fit', 'ふぃっと': 'fit', 'fit': 'fit',
+  '反転': 'invert', 'はんてん': 'invert', 'invert': 'invert',
+  '左右': 'flipH', 'さゆう': 'flipH', 'flip': 'flipH',
+  '上下': 'flipV', 'じょうげ': 'flipV',
+  'スクリーンショット': 'screenshot', 'screenshot': 'screenshot', 'キャプチャ': 'screenshot',
+  '印刷': 'print', 'いんさつ': 'print', 'print': 'print',
+  '再生': 'cine', 'さいせい': 'cine', 'play': 'cine',
+  '停止': 'cineStop', 'ていし': 'cineStop', 'stop': 'cineStop',
+  // Auto
+  'オート': 'autoWL', 'おーと': 'autoWL', 'auto': 'autoWL',
+};
+
+let recognition: SpeechRecognition | null = null;
+let isListening = false;
+let commandHandler: VoiceCommandHandler | null = null;
+
+export function isVoiceSupported(): boolean {
+  return 'SpeechRecognition' in window || 'webkitSpeechRecognition' in window;
+}
+
+export function isVoiceActive(): boolean {
+  return isListening;
+}
+
+export function startVoiceRecognition(handler: VoiceCommandHandler): boolean {
+  if (!isVoiceSupported()) return false;
+  if (isListening) return true;
+
+  const SpeechRecognition = window.SpeechRecognition || (window as unknown as { webkitSpeechRecognition: typeof window.SpeechRecognition }).webkitSpeechRecognition;
+  recognition = new SpeechRecognition();
+  recognition.continuous = true;
+  recognition.interimResults = false;
+  recognition.lang = 'ja-JP';
+  commandHandler = handler;
+
+  recognition.onresult = (event: SpeechRecognitionEvent) => {
+    const last = event.results[event.results.length - 1];
+    if (!last.isFinal) return;
+    const transcript = last[0].transcript.trim().toLowerCase();
+    console.log(`[Voice] heard: "${transcript}"`);
+
+    // Find matching command
+    for (const [key, cmd] of Object.entries(COMMAND_MAP)) {
+      if (transcript.includes(key)) {
+        console.log(`[Voice] command: ${cmd}`);
+        commandHandler?.onCommand(cmd);
+        return;
+      }
+    }
+  };
+
+  recognition.onerror = (event) => {
+    console.warn('[Voice] error:', event.error);
+    if (event.error === 'not-allowed' || event.error === 'service-not-allowed') {
+      isListening = false;
+    }
+  };
+
+  recognition.onend = () => {
+    // Auto-restart if still active
+    if (isListening && recognition) {
+      try { recognition.start(); } catch { /* ok */ }
+    }
+  };
+
+  try {
+    recognition.start();
+    isListening = true;
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+export function stopVoiceRecognition(): void {
+  isListening = false;
+  if (recognition) {
+    try { recognition.stop(); } catch { /* ok */ }
+    recognition = null;
+  }
+  commandHandler = null;
+}
