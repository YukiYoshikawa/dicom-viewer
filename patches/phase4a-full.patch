@@ -0,0 +1,76 @@
+/**
+ * GPU capability detection for optimal rendering path selection.
+ * Checks WebGPU → WebGL2 → WebGL fallback chain.
+ */
+
+export type GPUBackend = 'webgpu' | 'webgl2' | 'webgl';
+
+export interface GPUCapabilities {
+  backend: GPUBackend;
+  maxTextureSize: number;
+  maxContexts: number;
+  vendor: string;
+  renderer: string;
+  webgpuAvailable: boolean;
+}
+
+/** Check if WebGPU is available */
+async function checkWebGPU(): Promise<boolean> {
+  if (!('gpu' in navigator)) return false;
+  try {
+    const adapter = await navigator.gpu.requestAdapter();
+    return adapter !== null;
+  } catch {
+    return false;
+  }
+}
+
+/** Get WebGL info */
+function getWebGLInfo(): { vendor: string; renderer: string; maxTextureSize: number; version: 'webgl2' | 'webgl' } | null {
+  const canvas = document.createElement('canvas');
+
+  // Try WebGL2 first
+  let gl = canvas.getContext('webgl2') as WebGL2RenderingContext | null;
+  let version: 'webgl2' | 'webgl' = 'webgl2';
+  if (!gl) {
+    gl = canvas.getContext('webgl') as WebGLRenderingContext | null;
+    version = 'webgl';
+  }
+  if (!gl) return null;
+
+  const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
+  const vendor = debugInfo ? gl.getParameter(debugInfo.UNMASKED_VENDOR_WEBGL) : 'unknown';
+  const renderer = debugInfo ? gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) : 'unknown';
+  const maxTextureSize = gl.getParameter(gl.MAX_TEXTURE_SIZE);
+
+  // Clean up
+  const ext = gl.getExtension('WEBGL_lose_context');
+  if (ext) ext.loseContext();
+
+  return { vendor, renderer, maxTextureSize, version };
+}
+
+/** Detect GPU capabilities and optimal rendering backend */
+export async function detectGPU(): Promise<GPUCapabilities> {
+  const webgpuAvailable = await checkWebGPU();
+  const glInfo = getWebGLInfo();
+
+  const backend: GPUBackend = webgpuAvailable ? 'webgpu' : (glInfo?.version ?? 'webgl');
+
+  return {
+    backend,
+    maxTextureSize: glInfo?.maxTextureSize ?? 4096,
+    maxContexts: backend === 'webgpu' ? 32 : 16,
+    vendor: glInfo?.vendor ?? 'unknown',
+    renderer: glInfo?.renderer ?? 'unknown',
+    webgpuAvailable,
+  };
+}
+
+/** Get recommended max volume slices based on GPU capabilities */
+export function getRecommendedMaxSlices(caps: GPUCapabilities): number {
+  if (caps.webgpuAvailable) return 512; // WebGPU handles more data
+  if (caps.maxTextureSize >= 8192) return 256;
+  if (caps.maxTextureSize >= 4096) return 128;
+  return 64;
+}
