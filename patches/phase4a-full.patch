+import { annotation } from '@cornerstonejs/tools';
+
+interface HistoryEntry {
+  type: 'add' | 'remove';
+  annotationUID: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  snapshot: any; // serialized annotation
+}
+
+const MAX_HISTORY = 50;
+const undoStack: HistoryEntry[] = [];
+const redoStack: HistoryEntry[] = [];
+
+function cloneAnnotation(uid: string) {
+  const mgr = annotation.state;
+  // Search across all tool types
+  const toolNames = [
+    'Length', 'Angle', 'Bidirectional', 'ArrowAnnotate',
+    'CircleROI', 'EllipticalROI', 'RectangleROI', 'PlanarFreehandROI', 'Probe',
+  ];
+  for (const toolName of toolNames) {
+    try {
+      const anns = mgr.getAnnotations(toolName) ?? [];
+      const found = anns.find((a) => a.annotationUID === uid);
+      if (found) return JSON.parse(JSON.stringify(found));
+    } catch { /* skip */ }
+  }
+  return null;
+}
+
+/** Record an annotation addition for undo */
+export function recordAdd(uid: string): void {
+  const snap = cloneAnnotation(uid);
+  if (!snap) return;
+  undoStack.push({ type: 'add', annotationUID: uid, snapshot: snap });
+  if (undoStack.length > MAX_HISTORY) undoStack.shift();
+  redoStack.length = 0;
+}
+
+/** Record an annotation removal for undo */
+export function recordRemove(uid: string): void {
+  const snap = cloneAnnotation(uid);
+  if (!snap) return;
+  undoStack.push({ type: 'remove', annotationUID: uid, snapshot: snap });
+  if (undoStack.length > MAX_HISTORY) undoStack.shift();
+  redoStack.length = 0;
+}
+
+/** Undo the last operation */
+export function undo(): boolean {
+  const entry = undoStack.pop();
+  if (!entry) return false;
+
+  if (entry.type === 'add') {
+    // Was added → remove it
+    try { annotation.state.removeAnnotation(entry.annotationUID); } catch { /* ok */ }
+    redoStack.push(entry);
+  } else {
+    // Was removed → re-add it
+    try { annotation.state.addAnnotation(entry.snapshot); } catch { /* ok */ }
+    redoStack.push(entry);
+  }
+  return true;
+}
+
+/** Redo the last undone operation */
+export function redo(): boolean {
+  const entry = redoStack.pop();
+  if (!entry) return false;
+
+  if (entry.type === 'add') {
+    // Was added, undone (removed) → re-add
+    try { annotation.state.addAnnotation(entry.snapshot); } catch { /* ok */ }
+    undoStack.push(entry);
+  } else {
+    // Was removed, undone (re-added) → remove again
+    try { annotation.state.removeAnnotation(entry.annotationUID); } catch { /* ok */ }
+    undoStack.push(entry);
+  }
+  return true;
+}
+
+export function canUndo(): boolean { return undoStack.length > 0; }
+export function canRedo(): boolean { return redoStack.length > 0; }
+export function clearHistory(): void { undoStack.length = 0; redoStack.length = 0; }
