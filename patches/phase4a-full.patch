@@ -0,0 +1,222 @@
+import { useState, useEffect, useCallback, memo } from 'react';
+import { eventTarget } from '@cornerstonejs/core';
+import { annotation, Enums as csToolsEnums } from '@cornerstonejs/tools';
+import { X, Download, Undo2, Redo2 } from 'lucide-react';
+import { recordAdd, recordRemove, undo, redo } from '../core/annotationHistory';
+import styles from './MeasurementPanel.module.css';
+
+interface MeasurementItem {
+  id: string;
+  toolName: string;
+  label: string;
+  value: string;
+}
+
+const TOOL_LABELS: Record<string, string> = {
+  Length: '長さ',
+  Angle: '角度',
+  Bidirectional: '二方向',
+  ArrowAnnotate: '矢印',
+  CircleROI: '円ROI',
+  EllipticalROI: '楕円ROI',
+  RectangleROI: '矩形ROI',
+  PlanarFreehandROI: 'フリーハンドROI',
+  Probe: 'プローブ',
+};
+
+function formatAnnotationValue(ann: { metadata?: { toolName?: string }; data?: Record<string, unknown> }): string {
+  const toolName = ann.metadata?.toolName ?? '';
+  const data = ann.data as Record<string, unknown> | undefined;
+  if (!data) return '';
+
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  const cachedStats = data.cachedStats as any;
+
+  switch (toolName) {
+    case 'Length': {
+      const length = cachedStats?.['1']?.length ?? cachedStats?.length;
+      return length != null ? `${Number(length).toFixed(1)} mm` : '計測中...';
+    }
+    case 'Angle': {
+      const angle = cachedStats?.['1']?.angle ?? cachedStats?.angle;
+      return angle != null ? `${Number(angle).toFixed(1)}°` : '計測中...';
+    }
+    case 'Bidirectional': {
+      const stats = cachedStats?.['1'] ?? cachedStats;
+      const l = stats?.length;
+      const w = stats?.width;
+      if (l != null && w != null) return `${Number(l).toFixed(1)} × ${Number(w).toFixed(1)} mm`;
+      return '計測中...';
+    }
+    case 'ArrowAnnotate': {
+      const text = data.text ?? (data.handles as Record<string, unknown>)?.text ?? '';
+      return String(text) || '(矢印)';
+    }
+    case 'CircleROI':
+    case 'EllipticalROI':
+    case 'RectangleROI':
+    case 'PlanarFreehandROI': {
+      const stats = cachedStats?.['1'] ?? cachedStats;
+      if (!stats) return '計測中...';
+      const area = stats.area;
+      const mean = stats.mean;
+      const parts: string[] = [];
+      if (area != null) parts.push(`${Number(area).toFixed(1)} mm²`);
+      if (mean != null) parts.push(`mean: ${Number(mean).toFixed(1)}`);
+      return parts.length > 0 ? parts.join(', ') : '計測中...';
+    }
+    case 'Probe': {
+      const stats = cachedStats?.['1'] ?? cachedStats;
+      const value = stats?.value ?? stats?.mean;
+      return value != null ? `${Number(value).toFixed(1)} HU` : '計測中...';
+    }
+    default:
+      return '';
+  }
+}
+
+function getAnnotations(): MeasurementItem[] {
+  const items: MeasurementItem[] = [];
+  const mgr = annotation.state;
+
+  for (const toolName of Object.keys(TOOL_LABELS)) {
+    try {
+      const anns = mgr.getAnnotations(toolName) ?? [];
+      for (const ann of anns) {
+        items.push({
+          id: ann.annotationUID ?? '',
+          toolName,
+          label: TOOL_LABELS[toolName] ?? toolName,
+          value: formatAnnotationValue(ann),
+        });
+      }
+    } catch {
+      // Viewport not yet enabled — skip
+    }
+  }
+
+  return items;
+}
+
+// Annotation events from Cornerstone3D Tools
+const ANNOTATION_EVENTS = [
+  csToolsEnums.Events.ANNOTATION_ADDED,
+  csToolsEnums.Events.ANNOTATION_COMPLETED,
+  csToolsEnums.Events.ANNOTATION_MODIFIED,
+  csToolsEnums.Events.ANNOTATION_REMOVED,
+];
+
+export const MeasurementPanel = memo(function MeasurementPanel() {
+  const [items, setItems] = useState<MeasurementItem[]>([]);
+
+  const refresh = useCallback(() => {
+    setItems(getAnnotations());
+  }, []);
+
+  // Event-driven updates + record history for undo/redo
+  useEffect(() => {
+    refresh();
+    const handler = (evt: Event) => {
+      // eslint-disable-next-line @typescript-eslint/no-explicit-any
+      const detail = (evt as any).detail;
+      const uid = detail?.annotation?.annotationUID;
+      if (uid && evt.type === csToolsEnums.Events.ANNOTATION_COMPLETED) {
+        recordAdd(uid);
+      }
+      refresh();
+    };
+    for (const evt of ANNOTATION_EVENTS) {
+      eventTarget.addEventListener(evt, handler);
+    }
+    return () => {
+      for (const evt of ANNOTATION_EVENTS) {
+        eventTarget.removeEventListener(evt, handler);
+      }
+    };
+  }, [refresh]);
+
+  const handleDelete = useCallback((id: string) => {
+    try {
+      recordRemove(id);
+      annotation.state.removeAnnotation(id);
+      refresh();
+    } catch { /* ok */ }
+  }, [refresh]);
+
+  const handleUndo = useCallback(() => {
+    undo();
+    refresh();
+  }, [refresh]);
+
+  const handleRedo = useCallback(() => {
+    redo();
+    refresh();
+  }, [refresh]);
+
+  const handleClearAll = useCallback(() => {
+    try {
+      annotation.state.removeAllAnnotations();
+      setItems([]);
+    } catch { /* ok */ }
+  }, []);
+
+  const handleExportCSV = useCallback(() => {
+    if (items.length === 0) return;
+    const header = '種別,値';
+    const rows = items.map((item) => `"${item.label}","${item.value}"`);
+    const csv = [header, ...rows].join('\n');
