+/// Compute optimal Window Center / Window Width from 16-bit pixel data
+/// using percentile-based analysis (excludes outliers at 1st/99th percentile).
+/// Returns (window_center, window_width).
+pub fn auto_window_level_i16(data: &[i16]) -> (f64, f64) {
+    if data.is_empty() {
+        return (0.0, 1.0);
+    }
+
+    let len = data.len();
+
+    // Build sorted sample for percentile calculation
+    // For large images, sample every N-th pixel for speed
+    let sample_step = if len > 100_000 { len / 50_000 } else { 1 };
+    let mut samples: Vec<i16> = data.iter().step_by(sample_step).copied().collect();
+    samples.sort_unstable();
+
+    let n = samples.len();
+    // 1st and 99th percentile indices
+    let p1_idx = (n as f64 * 0.01) as usize;
+    let p99_idx = ((n as f64 * 0.99) as usize).min(n - 1);
+
+    let p1 = samples[p1_idx] as f64;
+    let p99 = samples[p99_idx] as f64;
+
+    let ww = (p99 - p1).max(1.0);
+    let wc = p1 + ww / 2.0;
+
+    (wc, ww)
+}
+
+/// Compute optimal WL/WW from 8-bit pixel data (canvas grayscale).
+pub fn auto_window_level_u8(data: &[u8]) -> (f64, f64) {
+    if data.is_empty() {
+        return (128.0, 256.0);
+    }
+
+    // Use histogram for fast percentile computation
+    let hist = compute_histogram(data);
+    let total = data.len() as f64;
+    let p1_target = (total * 0.01) as u32;
+    let p99_target = (total * 0.99) as u32;
+
+    let mut cumulative = 0u32;
+    let mut p1: f64 = 0.0;
+    let mut p99: f64 = 255.0;
+
+    for (i, &count) in hist.iter().enumerate() {
+        cumulative += count;
+        if cumulative >= p1_target && p1 == 0.0 && i > 0 {
+            p1 = i as f64;
+        }
+        if cumulative >= p99_target {
+            p99 = i as f64;
+            break;
+        }
+    }
+
+    let ww = (p99 - p1).max(1.0);
+    let wc = p1 + ww / 2.0;
+
+    (wc, ww)
+}
+
+/// Compute absolute difference between two 8-bit images.
+/// Output is scaled to full 0-255 range for visibility.
+pub fn compute_diff_map(a: &[u8], b: &[u8]) -> Vec<u8> {
+    let len = a.len().min(b.len());
+    let mut diff = vec![0u8; len];
+
+    // First pass: find max diff
+    let mut max_diff: u8 = 0;
+    for i in 0..len {
+        let d = (a[i] as i16 - b[i] as i16).unsigned_abs() as u8;
+        diff[i] = d;
+        if d > max_diff { max_diff = d; }
+    }
+
+    // Second pass: scale to 0-255
+    if max_diff > 0 {
+        for d in &mut diff {
+            *d = ((*d as u16 * 255) / max_diff as u16) as u8;
+        }
+    }
+
+    diff
+}
